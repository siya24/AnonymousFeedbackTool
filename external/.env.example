# Application
APP_NAME="Anonymous Feedback Tool"
APP_BASE_URL="http://localhost:8000"
# full  = intranet server — HR Console and all HR APIs are active
# public = internet-facing server — only the feedback portal and its supporting APIs
APP_MODE="full"
# Options: local | ldap | hybrid
HR_AUTH_MODE="hybrid"
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# Database
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="anonymous_feedback_tool"
DB_USERNAME="root"
DB_PASSWORD=""

# LDAP / Active Directory (leave blank if HR_AUTH_MODE=local)
LDAP_HOST=""
LDAP_PORT="389"
LDAP_BASE_DN=""
LDAP_DOMAIN=""
LDAP_BIND_PATTERN="%s"
LDAP_SERVICE_USER=""
LDAP_SERVICE_PASSWORD=""
LDAP_USE_TLS="false"
# Comma-separated AD group DNs or CNs allowed to access the HR Console
# Supports full DN (CN=HR,OU=Groups,DC=...) or just the CN (HR)
LDAP_HR_GROUPS=""
LDAP_IS_GROUPS=""
# Pipe-separated OU substrings matched against the user's distinguishedName
# e.g. LDAP_IS_OUS="OU=Information Services|OU=IT Admins"
LDAP_HR_OUS=""
LDAP_IS_OUS=""
# Pipe-separated values of the AD 'department' attribute
LDAP_HR_DEPARTMENTS=""
LDAP_IS_DEPARTMENTS=""
# Comma-separated usernames/emails allowed to bypass LDAP group restrictions in development
DEVELOPER_OVERRIDE_USERS=""

# Mail / Notifications
MAIL_FROM=""
MAIL_FROM_NAME="Voice Without Fear"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME=""
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=""
HR_NOTIFICATION_EMAIL=""
ETHICS_NOTIFICATION_EMAIL=""
